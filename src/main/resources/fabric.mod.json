{
	"schemaVersion": 1,
	"id": "render-distance",
	"version": "${version}",
	"name": "Render Distance Keybinds",
	"description": "Add Render Distance Hotkeying back post 1.19",
	"authors": [
		"_Average_Joe"
	],
	"contact": {
        "homepage": "https://github.com/Average-Joe-Create/Render-Distance-Keybinds",
        "sources": "https://github.com/Average-Joe-Create/Render-Distance-Keybinds"
    },
	"license": "MIT",
	"icon": "assets/render-distance/icon.png",
	"environment": "*",
	"entrypoints": {
